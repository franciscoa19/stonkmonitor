# ============================================================
#  STONK MONITOR — Environment Variables
#  Copy this to .env and fill in your real keys
# ============================================================

# --- Unusual Whales (https://unusualwhales.com) ---
# Required — options flow, dark pool, insider, congress feeds
UNUSUAL_WHALES_API_KEY=your_uw_api_key_here

# --- Alpaca (https://alpaca.markets) ---
# Paper trading: create free account at paper-api.alpaca.markets
# Live trading:  set ALPACA_PAPER=false and use live keys
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# --- Discord (optional — signal notifications) ---
# Create a webhook in any Discord channel: Channel Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here

# --- Pushover (optional — phone push notifications) ---
# Get token at https://pushover.net/apps/build
PUSHOVER_API_TOKEN=your_pushover_app_token
PUSHOVER_USER_KEY=your_pushover_user_key

# --- Telegram (recommended — one-tap trade execution) ---
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Start your bot → send /start to activate your chat_id (auto-resolved)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=0    # leave 0 — auto-resolved when you send /start to your bot

# --- Kalshi (prediction markets) ---
# Generate an API key at: https://kalshi.com/profile/api-keys
# KALSHI_KEY_ID     = the Key ID (UUID shown in dashboard)
# KALSHI_PRIVATE_KEY = either:
#   a) full PEM string: "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
#   b) path to .pem file: "C:/Users/you/kalshi_private.pem"
KALSHI_KEY_ID=your-kalshi-key-id-uuid
KALSHI_PRIVATE_KEY=C:/path/to/your/kalshi_private.pem
KALSHI_DEMO=false                # true = demo sandbox, false = live
KALSHI_SCAN_INTERVAL=300         # seconds between market scans
KALSHI_MIN_EDGE=0.05             # 5% minimum edge to surface an opportunity
KALSHI_MAX_BET_USD=500           # hard cap per bet
KALSHI_AUTO_EXECUTE=false        # true = auto-execute Kalshi buys without Telegram confirmation

# --- Dome API (https://docs.domeapi.io) ---
# Optional — enables cross-platform Kalshi ↔ Polymarket arbitrage scanner.
# Get a key at https://domeapi.io. Leave blank to disable cross-arb.
DOME_API_KEY=
DOME_BASE_URL=https://api.domeapi.io

# --- Polymarket CLOB (public, no auth required) ---
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# --- Cross-platform arb ---
CROSS_ARB_MIN_EDGE=0.05          # minimum edge (dollars, 0.05 = 5¢) to surface

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Signal Engine Thresholds (tune to taste) ---
MIN_PREMIUM_ALERT=50000        # minimum $ premium for options flow alert
MIN_DARKPOOL_SIZE=100000       # minimum $ for dark pool print alert
IV_RANK_THRESHOLD=80           # alert when IV rank > this (0-100)
IV_RANK_LOW_THRESHOLD=20       # alert when IV rank < this
SWEEP_SCORE_THRESHOLD=7        # 1-10 score to trigger notification

# --- Market Open/Close Noise Filter ---
# Extra score points required ON TOP of base thresholds during noisy windows.
# Applies to both notifications (Discord/Pushover) and auto-trade evaluation.
# Options/dark pool signals outside RTH are always suppressed (options don't trade).
OPEN_FIRST5_BUMP=2.0           # 09:30–09:35 ET — pure chaos, need score ≥9 to notify
OPEN_BUMP=1.5                  # 09:35–10:00 ET — still settling, need score ≥8.5
CLOSE_BUMP=0.5                 # 15:45–16:00 ET — MOC noise, need score ≥7.5

# --- Auto-Trade Engine ---
AUTO_TRADE_ENABLED=true
AUTO_TRADE_MAX_RISK_PCT=0.02        # 2% of portfolio equity per options/short trade
AUTO_TRADE_MAX_RISK_USD=50000       # effectively no cap — % governs everything
AUTO_TRADE_SCORE_THRESHOLD=9.0      # min signal score (raised from 8.5 — less is more)
AUTO_TRADE_PATTERN_THRESHOLD=9.5    # min pattern score (raised from 9.0)
AUTO_TRADE_MIN_DTE=3                # minimum days to expiry — 0-3d underperforms
AUTO_TRADE_MAX_DTE=10               # maximum days to expiry — 7-14d+ loses badly

# --- Auto-Trade Volume Controls (prevent over-trading) ---
AUTO_TRADE_MAX_TRADES_PER_DAY=3     # max confirmed trades per calendar day (ET)
AUTO_TRADE_MAX_OPEN_POSITIONS=4     # max concurrent open Alpaca positions

# --- Long-Term Equity Holds (insider cluster / congress + sweep patterns) ---
# Triggered by insider_cluster_buy / congress_plus_sweep patterns.
# Wider sizing (5% vs 2%) and wider bracket (TP +30%, SL -10%).
EQUITY_LONG_RISK_PCT=0.05           # 5% of equity per conviction equity hold
EQUITY_LONG_TARGET_PCT=30.0         # take profit at +30%
EQUITY_LONG_STOP_PCT=10.0           # stop loss at -10%

# --- Auto-Trade Quality Filters (data-driven from performance analysis) ---
# 1. Puts: historically 4% win rate — require exceptional signal
AUTO_TRADE_PUT_MIN_SCORE=9.5        # set to 10.0 to effectively disable put auto-trading

# 2. Market regime: skip directional trades when broad market disagrees
AUTO_TRADE_REGIME_SPY_TICKER=SPY
AUTO_TRADE_REGIME_BEAR_SKIP_PCT=1.5    # skip puts/shorts when SPY is up >+1.5% today
AUTO_TRADE_REGIME_BULL_SKIP_PCT=-2.0   # skip calls/longs when SPY is down >-2.0% today
AUTO_TRADE_REGIME_TREND_DAYS=5         # also check SPY's 5-day trend

# 4. Options price cap — $5-25 entries have 17-32% WR; cheap options outperform
AUTO_TRADE_MAX_OPTION_PRICE=8.0        # reject options priced above this at entry
AUTO_TRADE_MAX_OTM_PCT=0.20            # reject options >20% OTM (deep OTM has ~0% WR)

# 5. Per-ticker cooldown after a confirmed loss
AUTO_TRADE_TICKER_COOLDOWN_HOURS=72    # don't re-trade same ticker for 72h after a loss

# 6. Daily P&L circuit breaker — % based (preferred) + absolute dollar fallback
AUTO_TRADE_DAILY_LOSS_PCT=-0.05        # halt if day loss > 5% of account equity
AUTO_TRADE_DAILY_LOSS_LIMIT=-2000      # fallback: halt if realized P&L < -$2,000 today

# --- Position Monitor (TP/SL) ---
POS_MONITOR_INTERVAL=120       # seconds between position checks
POS_TP_PCT=80                  # take profit tier 1 at +80% — lock in gains
POS_TP_SELL_PCT=0.5            # sell 50% at TP1 (0.5 = half, 1.0 = all)
POS_TP2_PCT=175                # take profit tier 2 at +175% (fallback if trailing disabled)
POS_TP2_SELL_PCT=1.0           # sell 100% at TP2 (close remaining position)
POS_TRAIL_AFTER_TP=true        # enable trailing stop on runner after TP1
POS_TRAIL_PCT=20               # trail 20 percentage points below high watermark
POS_TRIM_PCT=-35               # trim at -35% loss
POS_TRIM_SELL_PCT=0.5          # sell 50% at trim
POS_SL_PCT=-40                 # stop loss at -40% — liquidate everything
