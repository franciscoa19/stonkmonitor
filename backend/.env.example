# ============================================================
#  STONK MONITOR — Environment Variables
#  Copy this to .env and fill in your real keys
# ============================================================

# --- Unusual Whales (https://unusualwhales.com) ---
# Required — options flow, dark pool, insider, congress feeds
UNUSUAL_WHALES_API_KEY=your_uw_api_key_here

# --- Alpaca (https://alpaca.markets) ---
# Paper trading: create free account at paper-api.alpaca.markets
# Live trading:  set ALPACA_PAPER=false and use live keys
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# --- Discord (optional — signal notifications) ---
# Create a webhook in any Discord channel: Channel Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here

# --- Pushover (optional — phone push notifications) ---
# Get token at https://pushover.net/apps/build
PUSHOVER_API_TOKEN=your_pushover_app_token
PUSHOVER_USER_KEY=your_pushover_user_key

# --- Telegram (recommended — one-tap trade execution) ---
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Start your bot → send /start to activate your chat_id (auto-resolved)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=0    # leave 0 — auto-resolved when you send /start to your bot

# --- Kalshi (prediction markets) ---
# Generate an API key at: https://kalshi.com/profile/api-keys
# KALSHI_KEY_ID     = the Key ID (UUID shown in dashboard)
# KALSHI_PRIVATE_KEY = either:
#   a) full PEM string: "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
#   b) path to .pem file: "C:/Users/you/kalshi_private.pem"
KALSHI_KEY_ID=your-kalshi-key-id-uuid
KALSHI_PRIVATE_KEY=C:/path/to/your/kalshi_private.pem
KALSHI_DEMO=false                # true = demo sandbox, false = live
KALSHI_SCAN_INTERVAL=300         # seconds between market scans
KALSHI_MIN_EDGE=0.05             # 5% minimum edge to surface an opportunity
KALSHI_MAX_BET_USD=500           # hard cap per bet
KALSHI_AUTO_EXECUTE=false        # true = auto-execute Kalshi buys without Telegram confirmation

# --- Dome API (https://docs.domeapi.io) ---
# Optional — enables cross-platform Kalshi ↔ Polymarket arbitrage scanner.
# Get a key at https://domeapi.io. Leave blank to disable cross-arb.
DOME_API_KEY=
DOME_BASE_URL=https://api.domeapi.io

# --- Polymarket CLOB (public, no auth required) ---
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# --- Cross-platform arb ---
CROSS_ARB_MIN_EDGE=0.05          # minimum edge (dollars, 0.05 = 5¢) to surface

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Signal Engine Thresholds (tune to taste) ---
MIN_PREMIUM_ALERT=50000        # minimum $ premium for options flow alert
MIN_DARKPOOL_SIZE=100000       # minimum $ for dark pool print alert
IV_RANK_THRESHOLD=80           # alert when IV rank > this (0-100)
IV_RANK_LOW_THRESHOLD=20       # alert when IV rank < this
SWEEP_SCORE_THRESHOLD=7        # 1-10 score to trigger notification

# --- Auto-Trade Engine ---
AUTO_TRADE_ENABLED=true
AUTO_TRADE_MAX_RISK_PCT=0.02   # 2% of portfolio equity per trade
AUTO_TRADE_MAX_RISK_USD=2500   # hard cap $ per trade
AUTO_TRADE_SCORE_THRESHOLD=8.5 # min signal score to queue a trade
AUTO_TRADE_PATTERN_THRESHOLD=9.0  # min pattern score to queue a trade
AUTO_TRADE_MIN_DTE=2           # minimum days to expiry (options)
AUTO_TRADE_MAX_DTE=21          # maximum days to expiry (no LEAPS chasing)

# --- Position Monitor (TP/SL) ---
POS_MONITOR_INTERVAL=120       # seconds between position checks
POS_TP_PCT=80                  # take profit tier 1 at +80% — lock in gains
POS_TP_SELL_PCT=0.5            # sell 50% at TP1 (0.5 = half, 1.0 = all)
POS_TP2_PCT=175                # take profit tier 2 at +175% — exit the runner
POS_TP2_SELL_PCT=1.0           # sell 100% at TP2 (close remaining position)
POS_TRIM_PCT=-35               # trim at -35% loss
POS_TRIM_SELL_PCT=0.5          # sell 50% at trim
POS_SL_PCT=-40                 # stop loss at -40% — liquidate everything
